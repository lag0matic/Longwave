[Unit]
Description=Longwave self-hosted API
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/longwave/server
EnvironmentFile=/opt/longwave/server/.env
ExecStart=/opt/longwave/server/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --proxy-headers --log-level info
ExecStartPre=/opt/longwave/server/.venv/bin/python -m alembic upgrade head
Restart=always
RestartSec=5
User=longwave
Group=longwave

[Install]
WantedBy=multi-user.target
